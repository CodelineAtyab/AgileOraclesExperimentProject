# Oracle APEX HMS - Git Ignore

# IDE files
.idea/
*.iml
.vscode/
*.swp
*.swo

# Build outputs
target/
build/
dist/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
*.log
logs/

# Temporary files
*.tmp
*.temp
*.bak

# Environment files
.env
.env.local
.env.production

# Database backup files
*.dmp
*.exp

# Compiled Java files
*.class
*.jar
*.war

# Node modules (if used for tooling)
node_modules/

# Secrets - NEVER commit these
*secret*
*password*
*credential*
